# ─────────────────────────────────────────────
# GMB Automation SaaS — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Get a free PostgreSQL DB from Neon: https://neon.tech
DATABASE_URL=postgresql://user:password@host:5432/gmb_saas?sslmode=require

# ── JWT ───────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── CORS ──────────────────────────────────────
# Set to your deployed Vercel frontend URL to restrict CORS in production
# allows all origins
FRONTEND_URL=https://your-app.vercel.app

# ── OpenAI (optional) ─────────────────────────
# If set: uses gpt-4o-mini for real AI post generation
# If not set: falls back to realistic mock content
OPENAI_API_KEY=sk-...

# ── Redis (BullMQ) ───────────────────────────
# Get a free Redis instance from Upstash: https://upstash.com
# Copy the "Redis URL" (starts with rediss://)
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────
NODE_ENV=development
PORT=3000
